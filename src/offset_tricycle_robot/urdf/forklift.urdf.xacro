<?xml version="1.0"?>
<robot name="gebot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================================== -->
  <!-- Robot Core: properties, macros, links, joints                              -->
  <!-- ========================================================================== -->

  <!-- Read controller lateral_offset directly from YAML so model and controller stay in sync -->
  <xacro:property name="controller_config" value="${xacro.load_yaml('$(find offset_tricycle_robot)/config/offset_tricycle_controller.yaml')}"/>
  <xacro:property name="lateral_offset" value="${controller_config['offset_tricycle_controller']['ros__parameters']['lateral_offset']}"/>

  <xacro:property name="base_width" value="0.79"/>
  <xacro:property name="base_length" value="1.896"/>
  <xacro:property name="base_height" value="0.05"/>

  <xacro:property name="wheel_zoff" value="0.025"/>

  <!-- Rear wheels: 150 mm diameter, 54 mm width -->
  <xacro:property name="rear_wheel_radius" value="0.115"/>
  <xacro:property name="rear_wheel_width" value="0.07"/>
  <!-- Front left (passive): 85 mm diameter, 70 mm width -->
  <xacro:property name="front_left_wheel_radius" value="0.115"/>
  <xacro:property name="front_left_wheel_width" value="0.07"/>
  <!-- Front right (drive): 230 mm diameter, 70 mm width -->
  <xacro:property name="front_right_drive_wheel_radius" value="0.115"/>
  <xacro:property name="front_right_drive_wheel_width" value="0.07"/>

  <!-- Wheelbase: front axle center to rear axle center [m] -->
  <xacro:property name="wheelbase" value="1.215"/>
  <!-- Rear track (distance between rear wheels) [m] -->
  <xacro:property name="rear_track" value="0.395"/>
  <!-- Front track (distance between front wheels) [m] -->
  <xacro:property name="front_track" value="0.51"/>

  <xacro:property name="rear_track_half" value="${rear_track / 2}"/>
  <xacro:property name="front_track_half" value="${front_track / 2}"/>
  <!-- Rear axle center x in base_chassis frame; front_axle_x = rear_axle_x + wheelbase -->
  <xacro:property name="rear_axle_x" value="-0.5"/>
  <xacro:property name="front_axle_x" value="${rear_axle_x + wheelbase}"/>
  <xacro:property name="rear_wheel_z" value="${-(rear_wheel_radius + wheel_zoff)}"/>
  <xacro:property name="front_left_wheel_z" value="${-(front_left_wheel_radius + wheel_zoff)}"/>
  <!-- Ground level (same for all wheels); front right drive wheel center z from chassis -->
  <xacro:property name="ground_z" value="${rear_wheel_z - rear_wheel_radius}"/>
  <xacro:property name="front_right_drive_wheel_center_z" value="${ground_z + front_right_drive_wheel_radius}"/>

  <!-- Definition of some commonly used inertial properties -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}" iyz="0.0" izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy = "0" ixz = "0" iyy="${(m/12) * (3*r*r + h*h)}" iyz = "0" izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- Materials (URDF visual) -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="wheel">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="myblue">
    <color rgba="0.0 0.0 0.5 1.0"/>
  </material>
  <material name="base">
    <color rgba="0.2 0.05 0.05 1.0"/>
  </material>
  <material name="lidar">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <!-- Robot Base -->
  <link name="base_link"/>

  <!-- Chassis -->
  <link name="base_chassis">
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="base"/>
    </visual>
    <xacro:box_inertia m="10" w="${base_width}" d="${base_length}" h="${base_height}"/>
  </link>

  <!-- base_link at rear axle center (odometry reference point); chassis origin is rear_axle_x ahead -->
  <joint name="base_link_joint" type="fixed">
    <origin xyz="${-rear_axle_x} 0.0 0.275" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="base_chassis"/>
  </joint>

  <!-- Front panel: visual indicator for front of vehicle -->
  <link name="front_panel">
    <visual>
      <geometry>
        <box size="0.15 ${base_width} 0.3"/>
      </geometry>
      <material name="lidar"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 ${base_width} 0.3"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" w="${base_width}" d="0.05" h="0.3"/>
  </link>

  <joint name="front_panel_joint" type="fixed">
    <parent link="base_chassis"/>
    <child link="front_panel"/>
    <origin xyz="${base_length/2 - 0.075} 0.0 ${base_height/2 + 0.15}"/>
  </joint>

  <!-- Rear wheels (driven by diff / not in tricycle model; macro: prefix, x, y in base_chassis) -->
  <xacro:macro name="rear_wheel" params="prefix x y">
    <link name="${prefix}">
      <collision>
        <geometry>
          <cylinder radius="${rear_wheel_radius}" length="${rear_wheel_width}"/>
        </geometry>
      </collision>
      <visual>
        <geometry>
          <cylinder radius="${rear_wheel_radius}" length="${rear_wheel_width}"/>
        </geometry>
        <material name="wheel"/>
      </visual>
      <xacro:cylinder_inertia m="1" r="${rear_wheel_radius}" h="${rear_wheel_width}"/>
    </link>
    <joint name="${prefix}_joint" type="continuous">
      <origin xyz="${x} ${y} ${rear_wheel_z}" rpy="${-pi/2} 0 0"/>
      <parent link="base_chassis"/>
      <child link="${prefix}"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.2"/>
    </joint>
  </xacro:macro>

  <xacro:rear_wheel prefix="rear_right_wheel" x="${rear_axle_x}" y="${-rear_track_half}" />
  <xacro:rear_wheel prefix="rear_left_wheel" x="${rear_axle_x}" y="${rear_track_half}" />

  <!-- Front right: driven wheel (steering + traction), 230 mm diameter, 70 mm width -->
  <link name="front_right_drive_wheel">
    <visual>
      <geometry>
        <cylinder radius="${front_right_drive_wheel_radius}" length="${front_right_drive_wheel_width}"/>
      </geometry>
      <material name="wheel"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${front_right_drive_wheel_radius}" length="${front_right_drive_wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1" r="${front_right_drive_wheel_radius}" h="${front_right_drive_wheel_width}"/>
  </link>

  <!-- Front left: passive/caster wheel, 85 mm diameter, 70 mm width -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${front_left_wheel_radius}" length="${front_left_wheel_width}"/>
      </geometry>
      <material name="wheel"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${front_left_wheel_radius}" length="${front_left_wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1" r="${front_left_wheel_radius}" h="${front_left_wheel_width}"/>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="${front_axle_x} ${front_track_half} ${front_left_wheel_z}" rpy="${-pi/2} 0 0"/>
    <parent link="base_chassis"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.2"/>
  </joint>

  <!-- Bearing (steering joint) – front right only -->
  <link name="bearing">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.045" length="0.04"/>
      </geometry>
      <material name="myblue"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.045" length="0.04"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1" r="0.0045" h="0.04"/>
  </link>

  <!-- Bearing at chassis top; z = base_height/2 so bearing_gear can sit at chassis center (z=0) -->
  <joint name="bearing_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.4" upper="1.4" velocity="0.5"/>
    <parent link="base_chassis"/>
    <child link="bearing"/>
    <origin xyz="${front_axle_x} ${-front_track_half} ${base_height/2}"/>
  </joint>

  <link name="bearing_gear">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.02" length="0.195"/>
      </geometry>
      <material name="myblue"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.02" length="0.195"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1" r="0.02" h="0.195"/>
  </link>

  <!-- Bearing_gear at chassis height (z=0 in base_chassis) -->
  <joint name="drive_unit" type="fixed">
    <parent link="bearing"/>
    <child link="bearing_gear"/>
    <origin xyz="0.0 0.0 ${-base_height/2}"/>
  </joint>

  <!-- Wheel center at same ground level as rear/front_left wheels -->
  <joint name="front_right_drive_wheel_joint" type="continuous">
    <axis xyz="0 0 1" />
    <parent link="bearing_gear"/>
    <child link="front_right_drive_wheel"/>
    <origin xyz="0.0 0.0 ${front_right_drive_wheel_center_z}" rpy="${-pi/2} 0.0 0.0"/>
    <dynamics damping="0.2" />
  </joint>

  <!-- Gazebo physics: wheels
       mu1 = primary friction (lateral / sideways for a wheel)
       mu2 = secondary friction (rolling / forward-backward for a wheel)
       - Drive wheel: high mu2 = less slip, odometry matches simulation better.
       - Lower mu1 on drive = more lateral slip when steering; lower mu2 = traction slip, controller overestimates distance.
       - Passive wheels: balanced mu1/mu2 so they roll but do not slide excessively. -->
  <gazebo reference="front_right_drive_wheel">
    <!-- mu2 high = less traction slip. mu1 high = less lateral slip when steering → tighter turn, Gazebo path closer to controller/EKF -->
    <mu1>1.8</mu1>
    <mu2>2.5</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="rear_left_wheel">
    <!-- Slightly lower mu1 lets rear slip a little laterally → can tighten turn to match tricycle model -->
    <mu1>0.5</mu1>
    <mu2>1.5</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="rear_right_wheel">
    <mu1>0.5</mu1>
    <mu2>1.5</mu2>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <!-- IMU Sensor -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.01" w="0.04" d="0.04" h="0.02"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_chassis"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.035" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <visualize>false</visualize>
      <topic>/imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo IMU system plugin (required for gz-sim) -->
  <gazebo>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
  </gazebo>

  <!-- Gazebo ground truth odometry publisher -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/model/gebot/odometry</odom_topic>
    </plugin>
  </gazebo>

  <!-- ========================================================================== -->
  <!-- Gazebo Sim Tricycle Control (from gz_tricycle_control.xacro)               -->
  <!-- ========================================================================== -->

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="bearing_joint">
      <command_interface name="position">
        <param name="min">-1.4</param>
        <param name="max">1.4</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    <joint name="front_right_drive_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find offset_tricycle_robot)/config/offset_tricycle_controller.yaml</parameters>
      <ros>
        <remapping>/tf:=tf</remapping>
        <remapping>/tf_static:=tf_static</remapping>
      </ros>
    </plugin>
  </gazebo>

  <!-- ========================================================================== -->
  <!-- Gazebo Sim Materials / visuals (from gazebo_sim_material.xacro)           -->
  <!-- ========================================================================== -->

  <gazebo reference="base_chassis">
    <visual>
      <material>
        <ambient>1.0 1.0 1.0 1</ambient>
        <diffuse>1.0 1.0 1.0 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <visual>
      <material>
        <ambient>0.3 0.3 0.3 1</ambient>
        <diffuse>0.3 0.3 0.3 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="rear_left_wheel">
    <visual>
      <material>
        <ambient>0.3 0.3 0.3 1</ambient>
        <diffuse>0.3 0.3 0.3 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="front_right_drive_wheel">
    <visual>
      <material>
        <ambient>0.3 0.3 0.3 1</ambient>
        <diffuse>0.3 0.3 0.3 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="front_left_wheel">
    <visual>
      <material>
        <ambient>0.3 0.3 0.3 1</ambient>
        <diffuse>0.3 0.3 0.3 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="bearing">
    <visual>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.1 0.1 0.1 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="bearing_gear">
    <visual>
      <material>
        <ambient>0.9 0.9 0.0 1</ambient>
        <diffuse>0.9 0.9 0.0 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="steering_link">
    <visual>
      <material>
        <ambient>1.0 1.0 1.0 1</ambient>
        <diffuse>1.0 1.0 1.0 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="steering_wheel">
    <visual>
      <material>
        <ambient>0.1 0.1 0.1 1</ambient>
        <diffuse>0.1 0.1 0.1 1</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="front_panel">
    <visual>
      <material>
        <ambient>0.8 0.0 0.0 1</ambient>
        <diffuse>0.8 0.0 0.0 1</diffuse>
      </material>
    </visual>
  </gazebo>

</robot>
